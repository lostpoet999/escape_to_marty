; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Escape to Marty"
run/main_scene="res://scenes_and_scripts/ui_main_menu/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.698039, 0.317647, 0.364706, 1)
boot_splash/show_image=false
config/icon="uid://ceqjt876orrnp"

[autoload]

Signalbus="*uid://dmpotobwyljm1"
PlayerData="*uid://y4ps6dt0vpeq"
MusicPlayer="*uid://b5146fvylaic"
GameManager="*uid://doymnbq1juguj"
ItemSpawner="*uid://fx2uws36tsjt"
DP="*uid://c53k2pfrfqs5g"
SFX="*uid://r23jyns7k0m7"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
gdscript/warnings/unsafe_property_access=1
gdscript/warnings/unsafe_cast=1
gdscript/warnings/unsafe_call_argument=1

[display]

