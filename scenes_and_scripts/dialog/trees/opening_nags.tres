[gd_resource type="Resource" script_class="DialogTree" format=3 uid="uid://copeningnags"]

[ext_resource type="Script" uid="uid://bkgp0oq7lrafl" path="res://scenes_and_scripts/dialog/dialog_tree.gd" id="1_tree"]
[ext_resource type="Script" uid="uid://da86xmy7akvas" path="res://scenes_and_scripts/dialog/dialog_beat.gd" id="2_beat"]

[sub_resource type="Resource" id="Resource_beat_1"]
script = ExtResource("2_beat")
text = "Longest. Dream. Ever. A little help out here?"

[sub_resource type="Resource" id="Resource_beat_2"]
script = ExtResource("2_beat")
text = "No paddle yet, so get those clicks warmed up. Click the shell!"

[sub_resource type="Resource" id="Resource_beat_3"]
script = ExtResource("2_beat")
text = "...what day is it? Still the weekend? Focus, stranger---clicking!"

[sub_resource type="Resource" id="Resource_beat_4"]
script = ExtResource("2_beat")
text = "These Shells of Denial don't break themselves. That's what you're for."

[sub_resource type="Resource" id="Resource_beat_5"]
script = ExtResource("2_beat")
text = "I'd break out myself, but my everything is brick right now."

[sub_resource type="Resource" id="Resource_beat_6"]
script = ExtResource("2_beat")
text = "Helloooo? Shiny purple shell? I'm IN it. Click it!"

[resource]
script = ExtResource("1_tree")
beats = Array[ExtResource("2_beat")]([SubResource("Resource_beat_1"), SubResource("Resource_beat_2"), SubResource("Resource_beat_3"), SubResource("Resource_beat_4"), SubResource("Resource_beat_5"), SubResource("Resource_beat_6")])
once_per_run = false
pick_random_beat = true
